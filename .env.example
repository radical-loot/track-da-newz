# OpenRouter (required — used for both LLM passes)
OPENROUTER_API_KEY=sk-or-...

# NewsData.io (free tier: 200 credits/day)
NEWSDATA_API_KEY=pub_...

# GNews (free tier: 100 req/day)
GNEWS_API_KEY=...

# Google BigQuery — for historical GDELT backfill
# Option 1: path to a service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
#
# Option 2: leave blank and run this once in your terminal:
#   gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=
